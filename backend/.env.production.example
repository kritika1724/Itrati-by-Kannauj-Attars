# Production environment template for Kannauj Attars backend
# Copy these keys into your hosting provider's environment settings.

NODE_ENV=production
PORT=10000

# Required core configuration
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
CORS_ORIGIN=https://your-domain.com

# Recommended for same-origin deploys and OAuth callbacks
FRONTEND_ORIGIN=https://your-domain.com
BACKEND_PUBLIC_URL=https://your-domain.com

# Admin bootstrap / admin email derivation
ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=only-needed-if-you-will-run-npm-run-create-admin

# Required for production uploads unless you intentionally allow local fallback
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=kannauj-attars

# Temporary fallback only. Prefer leaving this unset in production.
# ALLOW_LOCAL_UPLOADS=true

# Cookies
# Same-origin deploys usually work with these defaults.
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# COOKIE_DOMAIN=your-domain.com

# Checkout
COD_LIMIT=2000

# Monitoring
MONITOR_SLOW_REQUEST_MS=1500
MONITOR_ALERT_WINDOW_MS=300000
MONITOR_4XX_ALERT_THRESHOLD=25
MONITOR_5XX_ALERT_THRESHOLD=5
MONITOR_SLOW_ALERT_THRESHOLD=10

# Traffic hardening limits
RATE_LIMIT_USER_LOGIN_ATTEMPTS=8
RATE_LIMIT_ADMIN_LOGIN_ATTEMPTS=5
RATE_LIMIT_REGISTER_ATTEMPTS=4
RATE_LIMIT_SESSION_REFRESH=45
RATE_LIMIT_CONTACT_SUBMISSIONS=4
RATE_LIMIT_UPLOADS=12
RATE_LIMIT_ORDER_CREATES=8
RATE_LIMIT_ORDER_TRACKS=20
RATE_LIMIT_ORDER_MUTATIONS=10
RATE_LIMIT_PAYMENT_ACTIONS=12

# Public API CDN/edge caching
CACHE_PRODUCTS_BROWSER_S=60
CACHE_PRODUCTS_EDGE_S=300
CACHE_PRODUCTS_STALE_WHILE_REVALIDATE_S=1800
CACHE_PRODUCTS_STALE_IF_ERROR_S=21600
CACHE_ASSETS_BROWSER_S=300
CACHE_ASSETS_EDGE_S=1800
CACHE_ASSETS_STALE_WHILE_REVALIDATE_S=21600
CACHE_ASSETS_STALE_IF_ERROR_S=86400
CACHE_TAXONOMY_BROWSER_S=300
CACHE_TAXONOMY_EDGE_S=1800
CACHE_TAXONOMY_STALE_WHILE_REVALIDATE_S=21600
CACHE_TAXONOMY_STALE_IF_ERROR_S=86400

# Database tuning
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000

# Optional OAuth providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Optional payments
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
